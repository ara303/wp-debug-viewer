{
  "name": "wp-debug-viewer",
  "version": "1.0.1",
  "displayName": "WP Debug Viewer",
  "description": "Visual Studio Code extension to display a terminal that `tail`s your `debug.log` file.",
  "publisher": "ara303",
  "repository": {
    "type": "git",
    "url": "https://github.com/ara303/wp-debug-viewer"
  },
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:wpDebugViewer.logView"
  ],
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "wp-debug-container",
          "title": "WP Debug Viewer",
          "icon": "resources/log-icon.svg"
        }
      ]
    },
    "views": {
      "wp-debug-container": [
        {
          "icon": "resources/icon.svg",
          "type": "webview",
          "id": "wpDebugViewer.logView",
          "name": "Log Output"
        }
      ]
    },
    "configuration": {
      "title": "WP Debug Viewer",
      "properties": {
        "wpDebugViewer.path": {
          "type": "string",
          "default": "wp-content/debug.log",
          "description": "Relative path to the debug.log file."
        },
        "wpDebugViewer.fontSize": {
          "type": "number",
          "default": 12,
          "description": "Font size (in px) for the log output panel."
        }
      }
    }
  },
  "devDependencies": {
    "@types/vscode": "^1.60.0"
  }
}
